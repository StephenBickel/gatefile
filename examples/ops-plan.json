{
  "version": "2",
  "source": "ops-agent",
  "summary": "Rotate app config and validate health",
  "operations": [
    {
      "id": "op_file_1",
      "type": "file",
      "action": "update",
      "path": "infra/app.env",
      "before": "FEATURE_FLAG_X=false\nROTATION_EPOCH=2026-01-01\n",
      "after": "FEATURE_FLAG_X=true\nROTATION_EPOCH=2026-03-16\n"
    },
    {
      "id": "op_cmd_1",
      "type": "command",
      "executable": "./scripts/restart-app.sh",
      "args": [],
      "cwd": ".",
      "allowFailure": false
    },
    {
      "id": "op_cmd_2",
      "type": "command",
      "executable": "curl",
      "args": ["-fsS", "http://localhost:8080/health"],
      "cwd": ".",
      "allowFailure": false
    }
  ],
  "preconditions": [
    {
      "kind": "branch_is",
      "value": "main",
      "description": "Ops plans only apply from main branch"
    },
    {
      "kind": "env_present",
      "value": "ALLOW_OPS_APPLY",
      "description": "Explicit operator intent signal"
    }
  ]
}
