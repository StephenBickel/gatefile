{
  "name": "gatefile",
  "version": "0.3.0-alpha.0",
  "description": "Experimental alpha, not production-ready: review and approve AI agent file and shell side effects before execution.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gatefile": "dist/cli.js",
    "gatefile-mcp": "dist/mcp-server.js"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "cli": "ts-node src/cli.ts",
    "demo:e2e": "bash demo/public-launch-e2e.sh",
    "demo:playwright": "mkdir -p demo/output && npx playwright test -c demo/playwright.config.cjs",
    "demo:playwright:install": "npx playwright install chromium",
    "prepack": "npm run build",
    "test": "npm run build && node --require ./test-support/test-env.cjs --test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "agents",
    "ai",
    "governance",
    "terraform",
    "plan",
    "apply",
    "safety",
    "automation",
    "side-effects",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.17.30",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StephenBickel/gatefile.git"
  },
  "homepage": "https://github.com/StephenBickel/gatefile",
  "bugs": {
    "url": "https://github.com/StephenBickel/gatefile/issues"
  },
  "author": "Stephen Bickel"
}
