{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/StephenBickel/gatefile/blob/main/schema/gatefile.config.schema.json",
  "title": "Gatefile configuration",
  "type": "object",
  "properties": {
    "signers": { "$ref": "#/$defs/signers" },
    "hooks": { "$ref": "#/$defs/hooks" },
    "notifications": { "$ref": "#/$defs/notifications" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "not": {
        "required": ["hooks", "notifications"],
        "properties": {
          "hooks": {
            "type": "object",
            "required": ["onPlanCreated"],
            "properties": { "onPlanCreated": {} }
          },
          "notifications": {
            "type": "object",
            "required": ["onPlanCreated"],
            "properties": { "onPlanCreated": {} }
          }
        }
      }
    },
    {
      "not": {
        "required": ["hooks", "notifications"],
        "properties": {
          "hooks": {
            "type": "object",
            "required": ["onApprovalNeeded"],
            "properties": { "onApprovalNeeded": {} }
          },
          "notifications": {
            "type": "object",
            "required": ["onPlanApproved"],
            "properties": { "onPlanApproved": {} }
          }
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?=[\\s\\S]*\\S)[^\\u0000]+$"
    },
    "httpUrl": {
      "type": "string",
      "description": "A lowercase HTTP(S) URL. This schema applies a portable lexical prefilter; the runtime additionally parses the authority and port before dispatch.",
      "pattern": "^https?://[^\\s/?#\\\\]+(?:[/?#][^\\s\\\\]*)?$"
    },
    "publicKeyPem": {
      "type": "string",
      "description": "An Ed25519 public key encoded as one SPKI PEM block.",
      "pattern": "^\\s*-----BEGIN PUBLIC KEY-----\\r?\\nMCowBQYDK2VwAyEA[A-Za-z0-9+/]{42}[AEIMQUYcgkosw048]=\\r?\\n-----END PUBLIC KEY-----\\s*$"
    },
    "approvalKeyId": {
      "type": "string",
      "description": "A key ID derived from the canonical Ed25519 SPKI public key.",
      "pattern": "^gfk1_[a-f0-9]{16}$"
    },
    "signers": {
      "type": "object",
      "properties": {
        "trustedKeyIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/approvalKeyId" }
        },
        "trustedPublicKeys": {
          "type": "array",
          "items": { "$ref": "#/$defs/publicKeyPem" }
        }
      },
      "additionalProperties": false,
      "anyOf": [
        {
          "type": "object",
          "required": ["trustedKeyIds"],
          "properties": {
            "trustedKeyIds": { "type": "array", "minItems": 1 }
          }
        },
        {
          "type": "object",
          "required": ["trustedPublicKeys"],
          "properties": {
            "trustedPublicKeys": { "type": "array", "minItems": 1 }
          }
        }
      ]
    },
    "policyHook": {
      "type": "object",
      "properties": {
        "command": { "$ref": "#/$defs/nonEmptyString" },
        "cwd": { "$ref": "#/$defs/nonEmptyString" }
      },
      "required": ["command"],
      "additionalProperties": false
    },
    "notificationAction": {
      "type": "object",
      "description": "One or both of an HTTP(S) webhook URL and shell command.",
      "properties": {
        "webhook": { "$ref": "#/$defs/httpUrl" },
        "shell": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false,
      "anyOf": [
        {
          "type": "object",
          "required": ["webhook"],
          "properties": { "webhook": {} }
        },
        {
          "type": "object",
          "required": ["shell"],
          "properties": { "shell": {} }
        }
      ]
    },
    "hooks": {
      "type": "object",
      "description": "Blocking policy hooks. Deprecated lifecycle notification keys remain readable for migration.",
      "properties": {
        "beforeApprove": { "$ref": "#/$defs/policyHook" },
        "beforeApply": { "$ref": "#/$defs/policyHook" },
        "onPlanCreated": {
          "$ref": "#/$defs/notificationAction",
          "deprecated": true
        },
        "onApprovalNeeded": {
          "$ref": "#/$defs/notificationAction",
          "deprecated": true
        }
      },
      "additionalProperties": false
    },
    "notifications": {
      "type": "object",
      "description": "Best-effort lifecycle notifications dispatched after durable adapter writes.",
      "properties": {
        "onPlanCreated": { "$ref": "#/$defs/notificationAction" },
        "onPlanApproved": { "$ref": "#/$defs/notificationAction" }
      },
      "additionalProperties": false
    }
  }
}
